# Required: OpenAI API key with Realtime API access
OPENAI_API_KEY=sk-...

# Model + voice (defaults shown)
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=marin

# Optional: override OpenAI base URL (e.g. for Azure / proxy)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: comma-separated CORS origins (default: *)
# CORS_ORIGINS=http://localhost:3000,https://app.mr-ducky.example

# --- Twilio (phone-call mode) ---------------------------------------------
# Required to place real outbound calls via POST /calls. Without these, the
# browser /demo still works (WebRTC path); the phone path 503s.
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+15551234567

# Public HTTPS base URL of THIS service, reachable from Twilio's network.
# For local dev: `cloudflared tunnel --url http://localhost:8000` and paste the
# generated trycloudflare.com URL here. Twilio fetches TwiML from
# {PUBLIC_BASE_URL}/voice/twiml/{session_id} and opens a WSS to
# {PUBLIC_BASE_URL/https→wss}/voice/stream/{session_id}.
PUBLIC_BASE_URL=https://your-tunnel.trycloudflare.com

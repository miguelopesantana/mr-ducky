# Required: OpenAI API key with Realtime API access
OPENAI_API_KEY=sk-...

# Model + voice (defaults shown)
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=marin

# Optional: override OpenAI base URL (e.g. for Azure / proxy)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: comma-separated CORS origins (default: *)
# CORS_ORIGINS=http://localhost:3000,https://app.mr-ducky.example
